{
  "name": "fem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "vue": "npm run dev --workspace=apps/vue",
    "react": "npm run dev --workspace=apps/react",
    "preview:vue": "npm run preview --workspace=apps/vue",
    "preview:react": "npm run preview --workspace=apps/react",
    "build": "npm run build:react && npm run build:vue",
    "build:vue": "npm run build --workspace=apps/vue",
    "build:react": "npm run build --workspace=apps/react",
    "clean": "tsx scripts/clean-dist.ts",
    "clean:react": "tsx scripts/clean-dist.ts react",
    "clean:vue": "tsx scripts/clean-dist.ts vue",
    "lint": "npm run lint --workspaces",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.13.2",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "prettier": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "lodash-es": "^4.18.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  }
}
